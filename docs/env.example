# ============================================================
# Honey Shop — Variables de entorno
# ============================================================
# Copia este archivo como .env.local y rellena los valores.
# NUNCA subas .env.local a git.
# ============================================================

# Supabase
# Obtén estos valores en: https://supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Nota: NEXT_PUBLIC_* es seguro para el frontend.
# NUNCA uses service_role key en el cliente.
