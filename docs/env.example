# ============================================================
# Honey Shop — Variables de entorno
# ============================================================
# Copia este archivo como .env.local y rellena los valores.
# NUNCA subas .env.local a git.
# ============================================================

# ── Supabase (cliente + servidor) ──────────────────────────
# Obtén estos valores en: https://supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# ── Supabase (solo servidor) ────────────────────────────────
# Usado en src/app/api/orders/route.ts (NUNCA exponer en frontend)
# Project Settings → API → service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ── Notas de seguridad ──────────────────────────────────────
# NEXT_PUBLIC_* → visible en el bundle del cliente. Solo para anon key y URL.
# SUPABASE_SERVICE_ROLE_KEY → solo disponible en el servidor. Omitir NEXT_PUBLIC_.
# La service_role bypasea RLS — úsala únicamente en API Routes o Server Actions.
